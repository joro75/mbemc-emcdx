<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net462;netstandard2.0;net8.0</TargetFrameworks>

		<!--project-->
		<Product>Mercedes-Benz EMV DataExchange Library</Product>
		<PackageTags>EMC DataExchange, MBN50284</PackageTags>
		<Description>Implementation of the Mercedes-Benz EMC data exchange format</Description>

		<Copyright>(c) 2023-$([System.DateTime]::UtcNow.Year) MBition GmbH and other contributors.</Copyright>
		<Company>MBition GmbH</Company>
		<Authors>Andreas Rohleder</Authors>

		<!-- Analyzers -->
		<EnableNETAnalyzers>true</EnableNETAnalyzers>
		<AnalysisLevel>5</AnalysisLevel>
		<EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>

		<!-- Build settings -->
		<Deterministic>true</Deterministic>
		<DeterministicSourcePaths>false</DeterministicSourcePaths>
		<DelaySign>false</DelaySign>
		<DebugType>portable</DebugType>
		<CheckForOverflowUnderflow>true</CheckForOverflowUnderflow>

		<!-- Signature -->
		<AssemblyOriginatorKeyFile>$(SolutionDir)Mbemc.DataExchange.snk</AssemblyOriginatorKeyFile>
		<SignAssembly>True</SignAssembly>

		<!-- Package settings -->
		<PackageId>mbemc-emcdx</PackageId>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<GenerateAssemblyInfo>true</GenerateAssemblyInfo>
		<NeutralLanguage />
		<DebugSymbols>true</DebugSymbols>
		<IncludeSymbols>true</IncludeSymbols>
		<IncludeSymbolsInPackage>true</IncludeSymbolsInPackage>
		<SymbolPackageFormat>snupkg</SymbolPackageFormat>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<PackageProjectUrl>https://github.com/mercedes-benz/mbemc-emcdx</PackageProjectUrl>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
			<_Parameter1>Mbemc.DataExchange.Tests, </_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

	<!-- package references -->
	<ItemGroup>
		<PackageReference Include="System.Text.Json" Version="9.0.5" />
	</ItemGroup>

	<ItemGroup>
		<None Include="$(SolutionDir)README.md" Pack="true" PackagePath="" />
	</ItemGroup>
</Project>